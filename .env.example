# ── IRAssist environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real values.
# The app runs in DEMO MODE (seeded data, no auth enforcement) when these
# are unset, so you can develop the full UI without a live Supabase project.

# Supabase (auth + database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_NAME=IR Assist
NEXT_PUBLIC_APP_URL=http://localhost:3000
